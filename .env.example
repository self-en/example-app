# Copy this file to .env and fill in the values before running scripts/install.sh

# SSH host (must match a Host entry in ~/.ssh/config, or be a reachable hostname/IP)
SSH_HOST=ubuntu

# Base domain used for per-branch preview environments: <branch-slug>.${DOMAIN_SUFFIX}
DOMAIN_SUFFIX=self-en.local

# GitHub repo that ArgoCD watches. One Application is created per branch of this repo.
# GITHUB_OWNER MUST be a GitHub Organization, not a personal user account: ArgoCD's
# scmProvider generator only supports the GitHub "list org repos" API (confirmed by
# testing - a personal account returns 404). Create a free org if needed.
GITHUB_OWNER=changeme-org
GITHUB_REPO=changeme-repo

# GitHub token (repo scope for private repos; recommended even for public repos to
# avoid the 60 req/hour unauthenticated GitHub API rate limit hitting the ApplicationSet poller).
# Create at https://github.com/settings/tokens
GITHUB_TOKEN=

# Path inside the repo (relative to its root) containing the Helm chart to deploy for
# every branch. That chart MUST expose a `hostname` value consumed by an HTTPRoute
# template (see charts/example-app in this project for the reference contract).
APP_CHART_PATH=charts/example-app

# --- Advanced / usually fine to leave as-is ---
ARGOCD_NAMESPACE=argocd
GATEWAY_NAMESPACE=envoy-gateway-system
GATEWAY_NAME=eg
POSTGRES_NAMESPACE=postgres
POSTGRES_CLUSTER_NAME=postgres
ENVOY_GATEWAY_VERSION=v1.8.3
